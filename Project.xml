<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- _________________________ Application Settings _________________________ -->

	<app title="Scrapter Engine" packageName="com.huy1234th.scrapterEngine"
		package="com.huy1234th.scrapterEngine" file="game" main="Main" version="1.0.0"
		company="Huy1234TH" />
	<app preloader="flixel.system.FlxPreloader" />

	<!-- Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2 -->
	<set name="SWF_VERSION" value="11.8" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<!-- All targets -->
	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />

	<!-- HTML5 -->
	<window if="html5" resizable="true" />

	<!-- Desktop -->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" />

	<!-- macOS -->
	<window if="mac" orientation="auto" fullscreen="false" resizable="true" vsync="false"
		allow-high-dpi="true" />

	<!-- Mobile -->
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0"
		resizable="false" allow-shaders="true" allow-high-dpi="true" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />

	<source path="source" />

	<assets path="assets" exclude="*.ogg" if="web" />
	<assets path="assets" exclude="*.mp3" unless="web" />

	<!-- _______________________________ Libraries ______________________________ -->

	<!-- Default flixel library -->
	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="flixel-tools" />

	<!-- Iris -->
	<haxelib name="hscript-iris" />
	
	<!-- ______________________________ Haxedefines _____________________________ -->

	<!-- Optimise inputs, be careful you will get null errors if you don't use conditionals in your
	game -->
	<haxedef name="FLX_NO_MOUSE" if="mobile" />
	<haxedef name="FLX_NO_KEYBOARD" if="mobile" />
	<haxedef name="FLX_NO_TOUCH" if="desktop" />

	<!-- Disable the Flixel core debugger. Automatically gets set whenever you compile in release
	mode! -->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!-- Enable this for Nape release builds for a serious peformance improvement -->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<!-- Fix for Macros -->
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />

	<!-- Analyzer Optimization -->
	<haxedef name="analyzer-optimize" />

	<!-- This is self-explanatory -->
	<haxedef name="no-deprecation-warnings" />

	<!-- Pretty Error Reporting -->
	<haxedef name="message.reporting" value="pretty" />

	<!-- iOS Deployment Target -->
	<ios deployment="13.6" />

	<!-- _________________________________ Custom _______________________________ -->
</project>
